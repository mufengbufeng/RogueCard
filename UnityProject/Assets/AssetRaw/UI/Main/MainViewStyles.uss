/* 主菜单样式 */

.main-container {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
    background-color: var(--color-bg);
}

.main-content {
    justify-content: center;
    align-items: center;
    width: 800px;
    height: 600px;
}

.main-content > Label {
    margin-bottom: var(--spacing-md);
}

.main-content > Button {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
    width: 200px;
    height: 50px;
}
